{#
/**
 * @file
 * Empire app shell — cinematic sticky nav + footer around every page.
 * Faithful to the design (site.jsx Nav/Footer, empire.css). Presentation only.
 *
 * Available: empire_site_name, empire_site_initial, empire_subscribe_url,
 * empire_channel_label, empire_active ('home'|'videos'|'collections'),
 * is_front, logged_in.
 */
#}
<header class="nav{{ is_front ? '' : ' scrolled' }}" data-empire-nav>
  <a href="{{ path('<front>') }}" class="brand" rel="home" aria-label="{{ empire_site_name }} — {{ 'home'|t }}">
    <span class="brand-logo" aria-hidden="true">{{ empire_site_initial }}</span>
    <span class="brand-name">{{ empire_site_name }}</span>
  </a>

  <button class="nav-toggle btn-icon" type="button" aria-expanded="false" aria-controls="empire-nav-menu" aria-label="{{ 'Toggle menu'|t }}" data-empire-nav-toggle>
    <svg class="nav-toggle__open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    <svg class="nav-toggle__close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
  </button>

  <div class="nav-collapse" id="empire-nav-menu">
    <nav class="nav-links" aria-label="{{ 'Primary navigation'|t }}">
      <a href="{{ path('<front>') }}" class="nav-link{{ empire_active == 'home' ? ' on' : '' }}"{{ empire_active == 'home' ? ' aria-current="page"' : '' }}>{{ 'Home'|t }}</a>
      <a href="{{ empire_url_videos }}" class="nav-link{{ empire_active == 'videos' ? ' on' : '' }}"{{ empire_active == 'videos' ? ' aria-current="page"' : '' }}>{{ 'Videos'|t }}</a>
      <a href="{{ empire_url_collections }}" class="nav-link{{ empire_active == 'collections' ? ' on' : '' }}"{{ empire_active == 'collections' ? ' aria-current="page"' : '' }}>{{ 'Collections'|t }}</a>
    </nav>

    <div class="nav-spacer"></div>

    <div class="nav-right">
      {% if empire_subscribe_url %}
        <a class="btn btn-sub btn-sm" href="{{ empire_subscribe_url }}" target="_blank" rel="noopener noreferrer" title="{{ 'Subscribe on YouTube'|t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
          {{ 'Subscribe'|t }}
        </a>
      {% endif %}
      {% if logged_in %}
        <a class="btn-icon nav-gear" href="{{ empire_url_dashboard }}" title="{{ 'Empire dashboard'|t }}" aria-label="{{ 'Empire dashboard'|t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-2.7 1.1V21a2 2 0 0 1-4 0v-.1A1.6 1.6 0 0 0 7 19.4a1.6 1.6 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1A1.6 1.6 0 0 0 2.6 14H2.5a2 2 0 0 1 0-4h.1A1.6 1.6 0 0 0 4.6 7a1.6 1.6 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1A1.6 1.6 0 0 0 10 2.6V2.5a2 2 0 0 1 4 0v.1a1.6 1.6 0 0 0 2.7 1.1 1.6 1.6 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0-.3 1.8V10a1.6 1.6 0 0 0 1.5 1h.1a2 2 0 0 1 0 4h-.1a1.6 1.6 0 0 0-1.4.9z"/></svg>
        </a>
      {% endif %}
    </div>
  </div>
</header>

<main id="main-content" class="empire-main{{ is_front ? ' is-front' : '' }}">
  {% if empire_page_title %}
    <div class="page-head">
      <h1 class="page-title">{{ empire_page_title }}</h1>
      {% if empire_page_desc %}<p class="page-sub">{{ empire_page_desc }}</p>{% endif %}
    </div>
  {% endif %}
  {{ page.content }}
</main>

<footer class="foot">
  <div class="foot-main">
    <a href="{{ path('<front>') }}" class="foot-brand" rel="home">
      <span class="brand-logo" aria-hidden="true">{{ empire_site_initial }}</span>
      <span class="brand-name">{{ empire_site_name }}</span>
    </a>
    <nav class="foot-links" aria-label="{{ 'Footer'|t }}">
      <a href="{{ path('<front>') }}">{{ 'Home'|t }}</a>
      <a href="{{ empire_url_videos }}">{{ 'Videos'|t }}</a>
      <a href="{{ empire_url_collections }}">{{ 'Collections'|t }}</a>
      <a href="{{ empire_url_about }}">{{ 'About'|t }}</a>
      <a href="{{ empire_url_contact }}">{{ 'Contact'|t }}</a>
      <a href="{{ empire_url_privacy }}">{{ 'Privacy'|t }}</a>
      <a href="{{ empire_url_terms }}">{{ 'Terms'|t }}</a>
      {# Opens the Klaro consent manager (Decline / revoke YouTube + other external content). #}
      <a href="#" rel="open-consent-manager">{{ 'Privacy settings'|t }}</a>
    </nav>
    {% if empire_subscribe_url %}
      <a class="btn btn-sub btn-sm" href="{{ empire_subscribe_url }}" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        {{ 'Subscribe'|t }}
      </a>
    {% endif %}
  </div>
  <div class="foot-base">
    {# Showcase colophon: credit the platform (the site's own name is in .foot-brand above). #}
    <span>{{ 'powered by'|t }} <a href="https://www.drupal.org" target="_blank" rel="noopener noreferrer">Drupal</a></span>
    <span class="made">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8z"/></svg>
      {{ 'Built with'|t }} <a href="https://new.drupal.org" target="_blank" rel="noopener noreferrer"><b>Drupal CMS</b></a>
    </span>
  </div>
</footer>
