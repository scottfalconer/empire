{#
/**
 * @file
 * empire_video in `full` view mode → the watch page.
 *
 * Player (field_video → oEmbed) leads, then title, meta, description, tags.
 * `empire_watch_date` is built in empire_theme_preprocess_node().
 */
#}
<article{{ attributes.addClass('empire-watch') }}>
  {# The hand-tuned stage is now the video-stage SDC; the consent-gated field
     render is passed in as the `player` slot so Klaro gating is preserved. #}
  {% embed 'empire_theme:video-stage' with {
    poster: empire_watch_poster,
    unavailable: empire_unavailable|default(false) ? true : false,
    attributes: create_attribute(),
  } %}
    {% block player %}{{ content.field_video }}{% endblock %}
  {% endembed %}
  {# Info block is now the video-meta SDC; the field renders are passed in as
     slots so the per-field conditional wrappers stay in the node (Drupal glue). #}
  {% embed 'empire_theme:video-meta' with {
    title: label,
    date: empire_watch_date|default(''),
    source_url: empire_watch_source_url|default(''),
    attributes: create_attribute(),
  } %}
    {% block collection %}
      {% if content.field_collection|render|trim %}
        <span class="empire-watch__collection">{{ content.field_collection }}</span>
      {% endif %}
    {% endblock %}
    {% block description %}
      {% if content.field_content|render|trim %}
        <div class="empire-watch__desc">{{ content.field_content }}</div>
      {% endif %}
    {% endblock %}
    {% block tags %}
      {% if content.field_tags|render|trim %}
        <div class="empire-watch__tags">{{ content.field_tags }}</div>
      {% endif %}
    {% endblock %}
  {% endembed %}
  {{ include('empire_theme:share-bar', { title: label }, with_context = false) }}
</article>
