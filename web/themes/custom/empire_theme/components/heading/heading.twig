{# Empire heading — eyebrow + h{level}. #}
{% set tag = 'h' ~ (level|default(2)) %}
<div{{ attributes.addClass('empire-heading') }}>
  {% if eyebrow %}<span class="empire-heading__eyebrow">{{ eyebrow }}</span>{% endif %}
  {# Guard the heading element: never render an empty heading (WCAG 1.3.1). #}
  {% if text is not empty %}<{{ tag }} class="empire-heading__text">{{ text }}</{{ tag }}>{% endif %}
</div>
