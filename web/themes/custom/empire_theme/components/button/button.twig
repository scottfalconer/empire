{#
/**
 * @file
 * Empire button / CTA link — renders the design's `.btn` primitive (buttons.css).
 *
 * variant: primary|accent → accent · secondary|light → light · ghost · outline
 *          · default (neutral surface). size: default | sm | lg.
 */
#}
{% set vmap = {
  primary: 'btn-accent', accent: 'btn-accent',
  secondary: 'btn-light', light: 'btn-light',
  ghost: 'btn-ghost', outline: 'btn-outline', default: '',
} %}
{% set smap = { sm: 'btn-sm', lg: 'btn-lg', default: '' } %}
{% set vclass = vmap[variant|default('primary')]|default('btn-accent') %}
{% set sclass = smap[size|default('default')]|default('') %}
{# Render only with both a label (accessible name) and a destination — no empty
   links or focusable href="#" no-ops. Classes merged via the Attribute API so
   Canvas/contextual/admin attributes flow through the root element. #}
{% if label and url %}
  <a{{ attributes.addClass(['btn', vclass, sclass]|filter(c => c)) }} href="{{ url }}">{{ label }}</a>
{% endif %}
