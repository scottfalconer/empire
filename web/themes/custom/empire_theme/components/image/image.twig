{# Empire image — responsive, ratio-locked. #}
<figure{{ attributes.addClass('empire-image', 'empire-image--' ~ (ratio|default('16:9'))|replace({':': '-'})) }}>
  {% if src %}
    <img class="empire-image__img" src="{{ src }}" alt="{{ alt }}" loading="lazy">
  {% endif %}
  {% if caption %}<figcaption class="empire-image__caption">{{ caption }}</figcaption>{% endif %}
</figure>
