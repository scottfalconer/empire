{#
/**
 * @file
 * Empire card — the base list/grid/rail unit for a video.
 *
 * Props: title, url, image_src, image_alt, badge, meta.
 * Playback is NOT embedded here; the card links to the video page. Artwork is
 * resolved upstream (custom → oEmbed → placeholder) so this component only renders.
 */
#}
<article{{ (attributes ?? create_attribute()).addClass('empire-card') }}>
  {# Self-contained href guard (R13): reject javascript:/data:/protocol-relative. #}
  {%- set _u = url|default('#') -%}
  {%- set safe_url = (_u matches '~^(https?://|[/#?])~i' and not (_u starts with '//') and not (_u starts with '/\\')) ? _u : '#' -%}
  {# Give the wrapping link a clean accessible name (badge + title) so the date
     and decorative artwork don't get folded into a noisy link label. #}
  <a class="empire-card__link" href="{{ safe_url }}"{% if title %} aria-label="{{ badge ? badge ~ ': ' ~ title : title }}"{% endif %}>
    <div class="empire-card__media">
      {% if image_src %}
        {# Decorative when the title labels the link (avoids announcing it twice);
           fall back to a name only when there is no title (SDC-card-8). #}
        <img class="empire-card__img" src="{{ image_src }}" alt="{{ title ? '' : image_alt|default('Video thumbnail'|t) }}" loading="lazy">
      {% else %}
        <div class="empire-card__img empire-card__img--placeholder" aria-hidden="true">
          <span class="empire-card__placeholder-mark">▶</span>
        </div>
      {% endif %}
      {% if badge %}
        {# Compose the badge SDC (single source of truth) inside a positioning
           wrapper; the "New" upload pill is distinct from the accent default. #}
        <span class="empire-card__badge">{{ include('empire_theme:badge', { text: badge, variant: ((badge ~ '') == ('New'|t ~ '')) ? 'new' : 'accent' }, with_context=false) }}</span>
      {% endif %}
    </div>
    <div class="empire-card__body">
      {# Card title is the link's label, not a section heading (avoids heading-order skips). #}
      <div class="empire-card__title">{{ title }}</div>
      {% if meta %}<p class="empire-card__meta">{{ meta }}</p>{% endif %}
    </div>
  </a>
</article>
